# ── Python build artifacts ──
__pycache__/
*.py[cod]
*.egg-info/
.mypy_cache/
.pytest_cache/

# ── Virtual environments ──
.venv/
venvs/

# ── Generated scan reports (may contain sensitive network data) ──
reports/*

# ── Logs & session audit trail ──
logs/
data/*.log

# ── Runtime state / baselines (regenerated per-host) ──
data/*_baseline.json

# ── Backups & audit snapshots ──
.audit-backups/
hacker-tool-backups/

# ── Sync workspaces (keep dirs, ignore contents) ──
workspaces/local/*
workspaces/remote/*

# ── Keys & secrets (NEVER commit) ──
id_ed25519*
*.pub
*.pem
*.key
.smb_authfile

# ── Editor / OS noise ──
.DS_Store
*.swp
*.swo
*~

# ── Keep placeholder dirs (must stay last: last match wins) ──
!**/.gitkeep
.ssh/
